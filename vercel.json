{
  "name": "affi-asso",
  "buildCommand": "",
  "outputDirectory": "public",
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.3.0",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
